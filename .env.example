# Copy to .env and fill in. setup.sh creates this file for you and
# pre-fills LOCALSCRIBE_LLM_BACKEND based on the backend you pick.

# --- Required ---

# HuggingFace token with access to the gated pyannote models.
# Accept the terms at:
#   https://hf.co/pyannote/speaker-diarization-community-1
# Then create a token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alternative name; either works (HF_TOKEN takes precedence).
# HUGGING_FACE_HUB_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- LLM backend ---
# Which LLM provider to use for speaker identification + summarization.
#   claude_cli  - shells out to `claude`; uses Claude Pro/Max subscription
#   codex_cli   - shells out to `codex`;  uses ChatGPT Plus/Pro/Team subscription
#   gemini_cli  - shells out to `gemini`; uses Gemini Advanced / Google AI Pro
#   openai_api  - HTTP POST to any OpenAI-compatible Chat Completions endpoint
#                 (OpenAI, Anthropic API, Ollama, vLLM, LM Studio, Groq,
#                 OpenRouter, ...)
LOCALSCRIBE_LLM_BACKEND=claude_cli

# --- Required when LOCALSCRIBE_LLM_BACKEND=openai_api ---

# Bearer token. Required for hosted services (OpenAI, Anthropic API,
# Groq, etc.). Can be blank for local services like Ollama or LM Studio.
# OPENAI_API_KEY=sk-...

# Endpoint base URL. Default: https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# Model name. Provider-specific; default: gpt-4o
# OPENAI_MODEL=gpt-4o

# --- Optional ---

# Path to a Netscape-format cookies.txt for yt-dlp. Useful for
# age-gated, region-locked, or bot-flagged videos. Export from your
# browser with an extension like "Get cookies.txt" then point here.
# YOUTUBE_COOKIES=/path/to/cookies.txt
